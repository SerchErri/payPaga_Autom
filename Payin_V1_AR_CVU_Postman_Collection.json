{
	"info": {
		"_postman_id": "c0af0d43-9607-4606-9569-e1672fedac1a",
		"name": "Paypaga - V1 AR CVU Payin Dinaria",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Execute V1 CVU Payin (1-Click)",
			"event": [
				{
					"listen": "prerequest",
					"script": {
						"exec": [
							"const importeManual = 3500; // <------- ¡CAMBIAR MONTO AQUI!",
							"",
							"// 1. CREDENCIALES (Merchant A)",
							"const cid = \"4e9ac30a-edda-4806-a0cf-b648eadc5399\";",
							"const sec = \"qZnq5X-qtbzQIhD97fzyujXw74sw-hgs\";",
							"const authUrl = \"https://api.v2.dev.paypaga.com/oauth2/token\";",
							"const optUrl = \"https://api.v2.dev.paypaga.com/v1/transaction-config\";",
							"",
							"// 2. Generar una referencia única para cada pago",
							"const correlation = 'PAY-AR-' + Math.random().toString(36).substring(2, 11).toUpperCase();",
							"pm.variables.set(\"MerchantRefPayment\", correlation);",
							"",
							"console.log(\"🔄 Iniciando flujo automático por $\" + importeManual + \"...\");",
							"",
							"// PASO 1: Obtener Token",
							"pm.sendRequest({",
							"    url: authUrl,",
							"    method: 'POST',",
							"    header: { 'Content-Type': 'application/x-www-form-urlencoded' },",
							"    body: {",
							"        mode: 'urlencoded',",
							"        urlencoded: [",
							"            { key: \"client_id\", value: cid },",
							"            { key: \"grant_type\", value: \"client_credentials\" },",
							"            { key: \"client_secret\", value: sec }",
							"        ]",
							"    }",
							"}, function (err, resAuth) {",
							"    if (err || resAuth.code !== 200) {",
							"        console.error(\"❌ Error en Auth:\", err || resAuth.text());",
							"        return;",
							"    }",
							"    ",
							"    const token = resAuth.json().access_token;",
							"    pm.variables.set(\"AccessToken\", token);",
							"    console.log(\"✅ Token obtenido.\");",
							"",
							"    // PASO 2: Obtener Configuración",
							"    pm.sendRequest({",
							"        url: optUrl,",
							"        method: 'POST',",
							"        header: {",
							"            'Authorization': 'Bearer ' + token,",
							"            'Content-Type': 'application/json',",
							"            'DisablePartnerMock': 'true'",
							"        },",
							"        body: {",
							"            mode: 'raw',",
							"            raw: JSON.stringify({",
							"                country_code: \"AR\",",
							"                currency: \"ARS\",",
							"                transaction_total: importeManual,",
							"                merchant_transaction_reference: correlation",
							"            })",
							"        }",
							"    }, function (err2, resConf) {",
							"        if (err2 || resConf.code !== 200) {",
							"            console.error(\"❌ Error en Config:\", err2 || resConf.text());",
							"            return;",
							"        }",
							"        ",
							"        const data = resConf.json();",
							"        const txId = data.transaction_id || data.id || (data.data && data.data.transaction_id);",
							"        pm.variables.set(\"TransactionIdentifier\", txId);",
							"        console.log(\"✅ Configuración lista. ID:\", txId);",
							"    });",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{ "key": "Authorization", "value": "Bearer {{AccessToken}}", "type": "text" },
					{ "key": "Content-Type", "value": "application/json", "type": "text" },
					{ "key": "DisablePartnerMock", "value": "true", "type": "text" }
				],
				"body": {
					"mode": "raw",
					"raw": "{\r\n    \"transaction_id\": \"{{TransactionIdentifier}}\",\r\n    \"country_code\": \"AR\",\r\n    \"currency\": \"ARS\",\r\n    \"payment_method_code\": \"cvu\",\r\n    \"merchant_transaction_reference\": \"{{MerchantRefPayment}}\",\r\n    \"merchant_customer_id\": \"client_ar_01\",\r\n    \"transaction_fields\": [\r\n        { \"name\": \"first_name\", \"value\": \"Barão\" },\r\n        { \"name\": \"last_name\", \"value\": \"Praça\" },\r\n        { \"name\": \"document_number\", \"value\": \"20084908488\" },\r\n        { \"name\": \"document_type\", \"value\": \"CUIL\" },\r\n        { \"name\": \"email\", \"value\": \"barao.praca@ejemplo.com\" }\r\n    ],\r\n    \"allowOverUnder\": true\r\n}"
				},
				"url": {
					"raw": "https://api.v2.dev.paypaga.com/v1/payment",
					"protocol": "https",
					"host": [ "api", "v2", "dev", "paypaga", "com" ],
					"path": [ "v1", "payment" ]
				}
			}
		}
	],
	"variable": [
		{ "key": "TransactionIdentifier", "value": "" }
	]
}
